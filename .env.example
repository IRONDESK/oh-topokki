# Database (Neon Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"  # 풀링 (앱 런타임)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"                                   # 다이렉트 (마이그레이션, -pooler 없음)

# Better Auth
BETTER_AUTH_SECRET="openssl rand -base64 32 결과 (최소 32자)"
BETTER_AUTH_URL="http://localhost:3000"

# 네이버 지도 API
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=""

# 네이버 검색 API (가게 검색용)
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
